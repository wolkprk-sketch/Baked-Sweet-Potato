# adafruit_dht.py
import random

class DHT22:
    def __init__(self, pin):
        self._pin = pin
        self._temperature = 25.0
        self._humidity = 50.0
        print(f"[Mock DHT22] Initialized on pin {pin}")

    @property
    def temperature(self):
        # Simulate slight fluctuations
        return self._temperature + random.uniform(-0.5, 0.5)

    @property
    def humidity(self):
        # Simulate slight fluctuations
        return self._humidity + random.uniform(-1.0, 1.0)

    def exit(self):
        print(f"[Mock DHT22] Connection closed on pin {self._pin}")

class DHT11(DHT22):
    def __init__(self, pin):
        super().__init__(pin)
        print(f"[Mock DHT11] Initialized on pin {pin}")